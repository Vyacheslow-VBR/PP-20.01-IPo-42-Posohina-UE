<Window x:Class="PosohinaApp.SaleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Продажа" Height="320" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FAF0E6">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Продукт:" 
                   VerticalAlignment="Center" Margin="3"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="ProductComboBox" 
                  DisplayMemberPath="Name" SelectedValuePath="Id" Margin="3" Padding="3"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Количество:" 
                   VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="QuantityTextBox" 
                 Margin="3" Padding="3" PreviewTextInput="NumberValidationTextBox"
                 PreviewKeyDown="QuantityTextBox_PreviewKeyDown"
                 ToolTip="Максимальное количество: 1 000 000"/>

        <!-- Подсказка о лимите -->
        

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата:" 
                   VerticalAlignment="Center" Margin="3"/>
        <DatePicker Grid.Row="3" Grid.Column="1" x:Name="SaleDatePicker" 
                    Margin="3" Padding="3"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Сумма:" 
                   VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="TotalSumTextBox" 
                 Margin="3" Padding="3" IsReadOnly="True" 
                 Background="#F0F0F0" FontWeight="Bold"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="5">
            <Button x:Name="SaveButton" Content="OK" Width="70" Margin="3" 
                    Click="SaveButton_Click" IsDefault="True" Background="#528A6E"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="70" Margin="3" 
                    Click="CancelButton_Click" IsCancel="True" Background="#8B5A4C"/>
        </StackPanel>
    </Grid>
</Window>