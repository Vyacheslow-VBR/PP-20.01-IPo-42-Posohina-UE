<Window x:Class="PosohinaApp.PartnerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Партнер" Height="520" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FAF0E6">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Наименование:" 
                   VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NameTextBox" Margin="3" Padding="3"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип:" 
                   VerticalAlignment="Center" Margin="3"/>
        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="TypeComboBox" 
                  DisplayMemberPath="Name" SelectedValuePath="Id" Margin="3" Padding="3"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Рейтинг:" 
                   VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="RatingTextBox" 
                 Margin="3" Padding="3" PreviewTextInput="NumberValidationTextBox"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Скидка:" 
                   VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="DiscountTextBox" 
                 Margin="3" Padding="3" IsReadOnly="True" Background="#F0F0F0"/>

        <!-- АДРЕС -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Адрес:" 
                   VerticalAlignment="Top" Margin="3"/>
        <TextBox Grid.Row="4" Grid.Column="1" x:Name="AddressTextBox" 
                 Margin="3" Padding="3" TextWrapping="Wrap" 
                 AcceptsReturn="True" MinHeight="60" VerticalScrollBarVisibility="Auto"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Директор:" 
                   VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="DirectorTextBox" Margin="3" Padding="3"/>

        <TextBlock Grid.Row="6" Grid.Column="0" Text="Телефон:" 
                   VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="6" Grid.Column="1" x:Name="PhoneTextBox" Margin="3" Padding="3"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Email:" 
                   VerticalAlignment="Center" Margin="3"/>
        <TextBox Grid.Row="7" Grid.Column="1" x:Name="EmailTextBox" Margin="3" Padding="3"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Margin="5">
            <Button x:Name="SaveButton" Content="OK" Width="70" Margin="3" 
                    Click="SaveButton_Click" IsDefault="True" Background="#528A6E"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="70" Margin="3" 
                    Click="CancelButton_Click" IsCancel="True" Background="#8B5A4C"/>
        </StackPanel>
    </Grid>
</Window>